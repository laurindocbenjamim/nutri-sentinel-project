# SMARTurinalysis Environment Configuration Template
# Copy this file to '.env' and fill in your actual settings.

APP_NAME="SMARTurinalysis API"
DEBUG=False
PORT=8000

# Sentry DSN for error and performance tracking
SENTRY_DSN=""

# JWT configuration
JWT_SECRET=""
JWT_ALGORITHM="HS256"

# Cookie Security
SECURE_COOKIE=False

# MongoDB Configuration
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/<dbname>?retryWrites=true&w=majority"
MONGODB_DB_NAME="nutrisentinel_agent_ai"
MONGODB_COLLECTION="analysis"

# LLM Configuration
LLM_PROVIDER="groq"
LLM_MODEL="llama-3.1-8b-instant"
GROQ_API_KEY=""
GROQ_STT_MODEL="whisper-large-v3"

# Gemini Configuration
GEMINI_API_KEY=""
